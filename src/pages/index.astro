---
import Experiences from '../components/Experiences.astro';
import Projects from '../components/Projects.astro';
import Layout from '../layouts/Layout.astro';
import Contact from '../components/Contact.astro';
import SectionContainer from '../components/SectionContainer.astro';
import { SECTION } from '../components/Navbar.astro';
---

<Layout>
  <main class="flex flex-col w-full p-4 lg:w-3/7 lg:mx-auto pb-44">
    <section id={SECTION.HOME.id} class="mt-22 sm:mt-44 scroll-mt-24 flex flex-col gap-4 w-full">
      <div class="flex flex-col md:flex-row gap-2">
        <div class="flex gap-10">
          <div class="flex flex-col gap-4">
            <div>
              <h3 class="text-xl">Hola, Soy</h3>
              <h1 class="text-5xl font-bold">Gabriel Oyarzo Ramírez</h1>
              <h2 class="text-2xl">Ingeniero Civil en Informática</h2>
            </div>
            <p class="text-gray-600 mt-10 text-pretty sm:text-left">
              Soy Ingeniero Civil en Informática, titulado con distinción máxima por la Universidad
              de Los Lagos, Chile. Me desempeño en la intersección entre el desarrollo de software y
              la inteligencia de negocios, integrando sistemas SAP ECC, construyendo pipelines de
              datos y desarrollando aplicaciones web full-stack. Trabajo con herramientas como
              Python y R para automatizar procesos, generar visibilidad sobre los datos y apoyar la
              toma de decisiones mediante soluciones tecnológicas que mejoran el control de gestión
              y la eficiencia operativa.
            </p>

            <a class="w-fit" href="/Gabriel_Oyarzo_CV.pdf" download>
              <button class="btn btn-primary text-sm" aria-label="Descargar Curriculum Vitae">
                Descargar CV
              </button>
            </a>
          </div>

          <!-- <div class="flex flex-col gap-4">
            <h3>Encuéntrame en</h3>
            <nav class="flex gap-x-4">
              <button class="btn btn-ghost w-8 h-8" aria-label="Linkedin">
                <i class="fa-brands fa-linkedin-in"></i>
              </button>
              <button class="btn btn-ghost w-8 h-8" aria-label="Instagram">
                <i class="fa-brands fa-instagram"></i>
              </button>
              <button class="btn btn-ghost w-8 h-8" aria-label="X">
                <i class="fa-brands fa-x-twitter"></i>
              </button>
            </nav>
          </div> -->
        </div>
        <!-- <div class="w-2/5">
          <img
            class="rounded-full"
            src="https://external-content.duckduckgo.com/iu/?u=https%3A%2F%2Fimages.vexels.com%2Fmedia%2Fusers%2F3%2F145908%2Fraw%2F52eabf633ca6414e60a7677b0b917d92-male-avatar-maker.jpg&f=1&nofb=1&ipt=36611c8ed0511e9c02e9dc3688b1c6604db520fe2097a346ecbaf20c506112e8"
            alt="Gabriel Oyarzo"
          />
        </div> -->
      </div>
    </section>

    <SectionContainer id={SECTION.EXPERIENCE.id}>
      <Experiences />
    </SectionContainer>

    <SectionContainer id={SECTION.PROJECTS.id}>
      <Projects />
    </SectionContainer>

    <SectionContainer id={SECTION.ABOUT.id}>
      <h1 class="text-3xl font-bold">Sobre mí</h1>
      <p class="text-gray-600 text-pretty sm:text-left">
        Soy Gabriel Alexis Oyarzo Ramírez, Ingeniero Civil en Informática titulado con distinción
        máxima por la Universidad de Los Lagos, Chile. Durante mi formación y primeras experiencias
        profesionales he trabajado en el desarrollo de aplicaciones administrativas, integración de
        sistemas y análisis de datos, construyendo soluciones que combinan desarrollo de software
        con inteligencia de negocios. He trabajado con tecnologías como SAP ECC, Python, R, Angular,
        Express.js y bases de datos relacionales para desarrollar aplicaciones web, automatizar
        procesos y generar herramientas que apoyen la gestión y la toma de decisiones. Me motiva
        crear software que aporte valor real, mejorando la eficiencia de los procesos y facilitando
        el acceso a la información. Fuera del código, disfruto de la música y del aprendizaje
        autodidacta en distintas áreas.
      </p>
    </SectionContainer>

    <SectionContainer id={SECTION.CONTACT.id}>
      <Contact />
    </SectionContainer>
  </main>
</Layout>
